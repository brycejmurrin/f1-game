# Agent working directories (git worktrees created by background agents) and
# local Claude settings — but keep the shared developer skills tracked.
.claude/*
!.claude/skills/

# Node / Playwright
node_modules/
# scratch screenshot output from tools/apex-capture.mjs (regenerable)
scratch/
# survey/inspect screenshot dumps (regenerable)
.shots/
test-results/
playwright-report/

# regenerable screenshot dumps written via page.screenshot()/fs.writeFileSync
# (lap-audit, baku-audit, ui/parts/dev-tools captures). These are human-review
# galleries with NO toHaveScreenshot assertions — regenerate on demand. The
# golden visual-regression baselines live in tests/*-snapshots/ and stay tracked.
tests/ui-screenshots/

# generated follow-cam track traces (tests/track-trace.spec.js) — regenerable
tests/track-trace/

